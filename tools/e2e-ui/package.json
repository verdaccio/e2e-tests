{
  "name": "@verdaccio/e2e-ui",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Cypress plugin for Verdaccio UI e2e tests — run against any registry",
  "repository": {
    "type": "git",
    "url": "https://github.com/verdaccio/e2e-tests",
    "directory": "tools/e2e-ui"
  },
  "files": [
    "build"
  ],
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./commands": {
      "import": "./build/commands/index.js",
      "types": "./build/commands/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "clean": "rimraf build"
  },
  "peerDependencies": {
    "cypress": ">=12.0.0"
  },
  "devDependencies": {
    "@types/node": "20.19.0",
    "cypress": "15.12.0",
    "vite": "8.0.1"
  }
}
